                <label>Product Title</label>
               <textarea  name="rfq_details" required placeholder="Enter product details" required rows="6" cols="40"></textarea>
                <label style="display: none;">Quantity</label>
                <input type="number" name="quantity" min="1" placeholder="Enter quantity" style="display: none;">
                <button type="submit">Submit Now</button>
            </form>
        </div>
    </div>
</div>
