}

.custom-popup-form textarea:focus {
    outline: none;
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
}

/* Wrapper for the custom popup form */
.custom-popup-form {
    font-family: "Inter", sans-serif;
    text-align: center;
    padding: 0;
}

/* Open Modal Button */
.custom-popup-form .cpf-open-btn {
    padding: 12px 24px;
    background: #214332;
