}


/* ======================================================
   🎨 ANIMATIONS
   ====================================================== */
@keyframes badgePop {
  0%   { opacity: 0; transform: translateX(-50%) translateY(0) scale(0.6); }
  60%  { opacity: 1; transform: translateX(-50%) translateY(-10px) scale(1.05); }
  100% { opacity: 1; transform: translateX(-50%) translateY(-8px) scale(1); }
}

@keyframes badgePopArrow {
  0%   { opacity: 0; transform: translateX(-50%) translateY(4px) scale(0); }
  100% { opacity: 1; transform: translateX(-50%) translateY(0) scale(1); }
}

@keyframes badgePulse {
  0%, 100% { transform: translateX(-50%) translateY(-8px) scale(1); }
  50% { transform: translateX(-50%) translateY(-8px) scale(1.04); }
}


/* ======================================================
