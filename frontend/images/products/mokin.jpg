    transition: 0.2s;
font-size: 14px;
    font-family: 'Open Sans';
}

.custom-popup-form .cpf-open-btn:hover {
    background: #214332;
    transform: translateY(-1px);
}

/* Modal Background */
.custom-popup-form .cpf-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
    z-index: 999;
    padding: 20px;
}

/* Modal Box */
.custom-popup-form .cpf-modal-content {
    background: #fff;
    width: 100%;
    max-width: 420px;
    padding: 32px;
    border-radius: 18px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    position: relative;
    text-align: left;
    animation: cpf-popup 0.25s ease-out;
}

/* Popup animation */
@keyframes cpf-popup {
    from { transform: scale(0.9); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

/* Close Button */
.custom-popup-form .cpf-close {
    position: absolute;
    top: 14px;
    right: 18px;
    font-size: 22px;
    cursor: pointer;
    color: #6b7280;
    transition: 0.2s;
}

.custom-popup-form .cpf-close:hover {
    color: #000;
}

/* Form title */
.custom-popup-form h2 {
    text-align: center;
    font-weight: 600;
    margin-bottom: 25px;
    color: #111827;
    font-size: 1.5rem;
}

/* Labels */
.custom-popup-form label {
    display: block;
    margin-bottom: 6px;
    font-weight: 500;
    color: #374151;
}

/* Inputs */
.custom-popup-form input {
    width: 100%;
    padding: 12px 14px;
    margin-bottom: 18px;
    border-radius: 10px;
    border: 1px solid #d1d5db;
    font-size: 1rem;
    background: #f9fafb;
    transition: 0.2s;
}

.custom-popup-form input:focus {
    outline: none;
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
}

/* Submit Button */
.custom-popup-form button[type="submit"] {
    width: 100%;
    padding: 12px 16px;
    border: none;
    border-radius: 10px;
    background: #214332;
    color: #fff;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s;
}

.custom-popup-form button[type="submit"]:hover {
    background: #214332;
    transform: translateY(-1px);
}

.topbar {
  background-color: #214332;
  color: #fff;
  font-family: "Open Sans", sans-serif;
  padding: 0px 0;
}

.topbar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
