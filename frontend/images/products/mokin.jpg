/* Success Modal Background */
.cpf-success-modal {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
    z-index: 10000;
}

/* Center Box */
.cpf-success-modal-content {
    background: #fff;
    width: 90%;
    max-width: 380px;
    padding: 32px;
    border-radius: 18px;
    text-align: center;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
    animation: successPop 0.25s ease-out;
    position: relative;
}

/* Animation */
@keyframes successPop {
    from { transform: scale(0.85); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

/* Close button */
.cpf-success-close {
    position: absolute;
    top: 14px;
    right: 18px;
    font-size: 22px;
    cursor: pointer;
    color: #6b7280;
    transition: 0.2s;
}
.cpf-success-close:hover { color: #000; }

/* Success Icon */
.cpf-success-icon {
    width: 65px;
    height: 65px;
    background: #11a452;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #fff;
    font-size: 32px;
    margin: 0 auto 14px;
    box-shadow: 0 6px 16px rgba(0,0,0,0.15);
}

/* Title */
