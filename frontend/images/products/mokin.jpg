<script>
document.addEventListener("DOMContentLoaded", () => {
  
  const variantCards = document.querySelector(".variant-cards");
  if (!variantCards) return;

  // Shopify exposes product JSON through the global "product" object on PDP
  const productJson = window.product || window.meta?.product;

  if (!productJson) return;

  // If the product has ONLY ONE variant → simple product → hide the cards
  if (productJson.variants && productJson.variants.length <= 1) {
    variantCards.style.display = "none";
  }

});
</script>
<script src="//managramasethu.in/cdn/shop/t/3/assets/product-quick-view.js?v=108327601157308923661765444682" defer="defer"></script>
