  <style>/* /* ======================================================
   ✅ DESKTOP — 8th MENU ITEM
   ====================================================== */
.m-menu__item:nth-child(8) .m-menu__link--main {
  position: relative;
}

.m-menu__item:nth-child(8) .m-menu__link--main::before {
  content: "Coming Soon";
  position: absolute;
  left: 90%;
  top: 10px;
  transform: translateX(-50%) translateY(-8px);
  font-size: 10px;
  font-weight: 700;
  padding: 4px 6px;
  border-radius: 999px;
  background: linear-gradient(135deg,#ff5a5f,#ff9472);
  color: #fff;
  opacity: 0;
  animation: badgePop 1.2s ease forwards, badgePulse 2.2s ease 1.2s infinite;
}

.m-menu__item:nth-child(8) .m-menu__link--main::after {
  content: "";
  position: absolute;
  left: 82%;
  top: 19px;
  width: 8px;
  height: 8px;
  transform: translateX(-50%);
  background: linear-gradient(135deg,#ff5a5f,#ff9472);
  clip-path: polygon(100% 0, 0 100%, 170% 65%);
  opacity: 0;
  animation: badgePopArrow 1.2s ease forwards;
}


/* ======================================================
