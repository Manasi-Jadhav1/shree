<!-- Font Awesome -->
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
/>
<script>
function openModal() {
    document.getElementById("cpfModal").style.display = "flex";
}
function closeModal() {
    document.getElementById("cpfModal").style.display = "none";
}
window.onclick = function(event) {
    let modal = document.getElementById("cpfModal");
    if(event.target === modal) modal.style.display = "none";
}

document.getElementById("cpfForm").addEventListener("submit", function(e){
    e.preventDefault();

    const rfq_details = this.rfq_details.value.trim();
    if(!rfq_details){
        alert("Please enter RFQ details.");
        return;
    }

    fetch("https://jada.dev/api/method/gramasethu.api.rfq.save_rfq_details", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ rfq_details: rfq_details })
    })
    .then(res => res.json())
    .then(res => {
        if(res.message && res.message.status === "success"){
            this.reset();
            closeModal(); // close the RFQ form popup
            openSuccessModal(); // open success modal
        } else {
            alert("Failed to save RFQ.");
        }
    })
    .catch(err => {
        console.error(err);
        alert("Error saving RFQ. Check console.");
    });
});

// Show Success Popup
function openSuccessModal() {
    const modal = document.getElementById("cpfSuccessModal");
    modal.style.display = "flex";

    // Auto close after 3 sec
    setTimeout(() => {
        modal.style.display = "none";
    }, 3000);
}

// Manual Close
function closeSuccessModal() {
    document.getElementById("cpfSuccessModal").style.display = "none";
}

</script>
</section>


